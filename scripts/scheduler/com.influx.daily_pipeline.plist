<?xml version="1.0" encoding="UTF-8"?>
<!-- macOS launchd 雛形: 毎朝 7:00 JST に daily_pipeline.py を実行
     インストール: cp scripts/scheduler/com.influx.daily_pipeline.plist ~/Library/LaunchAgents/
                   launchctl load ~/Library/LaunchAgents/com.influx.daily_pipeline.plist
     アンインストール: launchctl unload ~/Library/LaunchAgents/com.influx.daily_pipeline.plist
     ログ確認: tail -f /Users/masaaki_nagasawa/Desktop/biz/influx/output/pipeline_log/launchd.log
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.influx.daily_pipeline</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>bash</string>
        <string>-lc</string>
        <string>cd /Users/masaaki_nagasawa/Desktop/biz/influx &amp;&amp; python3 scripts/daily_pipeline.py --no-llm-compose</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/masaaki_nagasawa/Desktop/biz/influx/output/pipeline_log/launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/masaaki_nagasawa/Desktop/biz/influx/output/pipeline_log/launchd.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TZ</key>
        <string>Asia/Tokyo</string>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
